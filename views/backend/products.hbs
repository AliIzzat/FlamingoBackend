<link rel="stylesheet" href="/css/admin.css">

<h1>Manage Products</h1>

<div style="display:flex; gap:10px; margin-bottom:12px;">
  <a href="/admin/dashboard" class="DashBtn">← Return to Dashboard</a>
  <a href="/admin/stores" class="DashBtn">← Back to Stores</a>
</div>

<section style="margin: 1px 0 16px 0; padding: 12px; border: 1px solid #ddd; border-radius: 10px;">
  <h3>Select Store</h3>

  <form method="GET" action="/admin/products" id="productPickerForm" class="filters-row">
    <div style="display:flex; gap:12px; align-items:end; flex-wrap:wrap;">

      <div>
        <label>Category:</label><br>
        <select name="type" id="typeFilter" style="height:30px; min-width:180px;">
          <option value="">-- Select Category --</option>
      
        {{!-- This categories --}}
          {{#each categories}}
            <option value="{{key}}" {{#if (eq ../selectedType key)}}selected{{/if}}>
              {{key}} — {{name_en}}
            </option>
          {{/each}}
        </select>
      </div>

      <div>
        <label>Store:</label><br>
        <select name="storeId" id="storeIdFilter" style="height:30px; min-width:260px;">
          <option value="">-- Select Store --</option>

  {{!-- This storeForPicker  --}}
          {{#each storesForPicker}}
            <option value="{{_id}}" {{#if (eq _id ../selectedStoreId)}}selected{{/if}}>
              {{name}} ({{type}})
            </option>
          {{/each}}
        </select>
      </div>

      <div>
        <button type="submit" class="DashBtn" style="height:32px;">Open</button>
      </div>

    </div>
  </form>
</section>

{{#if selectedStore}}
<section style="margin: 1px 0 16px 0; padding: 12px; border: 1px solid #ddd; border-radius: 10px;">
  <h3>Add Product for: {{selectedStore.name}} ({{selectedStore.type}})</h3>

  <form action="/admin/products/create" method="POST" enctype="multipart/form-data" class="card product-form">
    <input type="hidden" name="storeId" value="{{selectedStore._id}}" />
    <input type="hidden" name="category" value="{{selectedStore.type}}">
    <input type="hidden" name="returnTo" value="/admin/products?type={{selectedStore.type}}&storeId={{selectedStore._id}}">

    <div class="form-grid">

      <label>Name (EN):</label>
      <input name="name_en" style="height: 30px;" required />

      <label>Name (AR):</label>
      <input name="name_ar" style="height: 30px;" />

      <label>Category:</label>
      <input type="text" value="{{selectedStore.type}}" style="height: 30px;" disabled />

      <label>Price:</label>
      <input name="price" type="number" step="0.01" style="height: 30px;" required />

      <label>Image:</label>
      <input type="file" name="image" accept="image/*" />

      <label>Offer?</label>
      <select name="offer" style="height: 30px;">
        <option value="false">No</option>
        <option value="true">Yes</option>
      </select>

      <label>Offer Price:</label>
      <input name="offerPrice" type="number" step="0.01" style="height: 30px;" />

      <label>Details (EN):</label>
      <textarea name="details_en" rows="3"></textarea>

      <label>Details (AR):</label>
      <textarea name="details_ar" rows="3"></textarea>

      <label>Active:</label>
      <select name="isActive" style="height: 30px;">
        <option value="true" selected>Yes</option>
        <option value="false">No</option>
      </select>

    </div>

    <div class="btn-row-form">
      <button type="submit" class="DashBtn">Create Product</button>
    </div>
  </form>
</section>

<section style="margin: 1px 0; padding: 12px; border: 1px solid #ddd; border-radius: 10px;">
  <h3>Existing Products for {{selectedStore.name}}</h3>

  {{#if products.length}}
  <table class="dashboard-table">
    <thead>
      <tr>
        <th>Image</th>
        <th>Name (EN)</th>
        <th>Name (AR)</th>
        <th>Price</th>
        <th>Offer</th>
        <th>Offer Price</th>
        <th>Active</th>
        <th class="column-eight">Actions</th>
      </tr>
    </thead>

    <tbody>
      {{#each products}}
    <tr>
    <form id="updateForm-{{_id}}" action="/admin/products/update/{{_id}}" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="returnTo" value="/admin/products?type={{../selectedStore.type}}&storeId={{../selectedStore._id}}">

      <td>
        <div class="img-cell">
          <div class="thumb-box">
            {{#if image}}<img src="{{image}}" alt="" class="thumb" />{{/if}}
          </div>
          <input type="file" name="image" accept="image/*" class="file-input" />
        </div>
      </td>

      <td>
        <input name="name" value="{{name}}" required style="width:180px; height:30px;" />
      </td>

      <td>
        <input name="name_ar" value="{{name_ar}}" style="width:160px; height:30px;" />
      </td>

      <td>
        <input name="price" value="{{price}}" type="number" step="0.01" style="width:70px; height:30px;" />
      </td>

      <td>
        <select name="offer" style="height:30px;">
          <option value="true" {{#if offer}}selected{{/if}}>Yes</option>
          <option value="false" {{#unless offer}}selected{{/unless}}>No</option>
        </select>
      </td>

      <td>
        <input name="offerPrice" value="{{offerPrice}}" type="number" step="0.01" style="width:70px; height:30px;" />
      </td>

      <td>
        <select name="isActive" style="height:30px;">
          <option value="true" {{#if isActive}}selected{{/if}}>Yes</option>
          <option value="false" {{#unless isActive}}selected{{/unless}}>No</option>
        </select>
      </td>

      <td class="actions-cell">
        <div class="actions-row">
          <button type="submit" class="btn-save">Save</button>
        </div>
      </td>
    </form>
  </tr>

  <tr>
    <td colspan="8" class="details-row">
      <div class="details-grid">
        <div>
          <label>Details (EN):</label>
          <textarea name="details" form="updateForm-{{_id}}" rows="2" style="width:100%;">{{details}}</textarea>
        </div>
        <div>
          <label>Details (AR):</label>
          <textarea name="details_ar" form="updateForm-{{_id}}" rows="2" style="width:100%;">{{details_ar}}</textarea>
        </div>
      </div>
    </td>
  </tr>
  {{/each}}
      
    </tbody>
  </table>
  {{else}}
    <p>No products found for this store.</p>
  {{/if}}
</section>
{{else}}
<section style="margin: 1px 0; padding: 16px; border: 1px dashed #ccc; border-radius: 10px;">
  <p>Please select a category and store to manage products.</p>
</section>
{{/if}}

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const typeSelect = document.getElementById("typeFilter");
    const storeSelect = document.getElementById("storeIdFilter");
    const form = document.getElementById("productPickerForm");

    if (typeSelect && form) {
      typeSelect.addEventListener("change", function () {
        const params = new URLSearchParams(window.location.search);
        params.set("type", typeSelect.value);
        params.delete("storeId");
        window.location.href = "/admin/products?" + params.toString();
      });
    }

    if (storeSelect && form) {
      storeSelect.addEventListener("change", function () {
        form.submit();
      });
    }
  });
</script>

<style>
  .dashboard-table {
    width: 100%;
    border-collapse: collapse;
    border:solid 2px red;
    margin-bottom: 2rem;
  }
  .column-eight{
    width: 500px;
  }

  .dashboard-table th,
  .dashboard-table td {
    border: 1px solid #ff4b2b;
    padding: 0.75rem;
    text-align: left;
    vertical-align: middle;
  }

  .dashboard-table th {
    background-color: #ff4b2b;
    color: #fff;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 10px;
    align-items: center;
  }

  .btn-row-form {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin-top: 14px;
    flex-wrap: wrap;
  }

  .img-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .thumb-box {
    width: 70px;
    height: 70px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ddd;
    border-radius: 6px;
    background: #fff;
  }

  .thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .file-input {
    width: 120px;
    font-size: 12px;
  }

  .actions-cell {
    border-bottom: none !important;
  }

  .actions-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .inline-form {
    margin: 0;
  }

  .actions-row button {
    white-space: nowrap;
    height: 30px;
    border-radius: 6px;
    border: 1px solid #ccc;
  
    cursor: pointer;
  }

  .btn-save {
    background-color: rgb(53, 236, 53);
    width: 150px;
  }

  .btn-toggle {
    background-color: rgb(250, 250, 93);
    width: 150px;
  }

  .btn-delete {
    background-color: rgb(255, 120, 120);
    width: 150px;
  }

  .details-row td {
    background: #fafafa;
    border-top: none;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .dashboard-table tr td.actions-cell {
  border-top: none !important;
}
.dashboard-table td.actions-cell {
  border-left: none !important;
  border-right: none !important;
  border-top: none !important;
}

</style>