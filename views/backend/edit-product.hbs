<div class="container">
  <h2>Edit Product</h2>

  <form action="/backend/products/edit/{{product._id}}" method="POST" enctype="multipart/form-data" class="product-form">
    
    <div class="form-group">
      <label>Product Name (EN)</label>
      <input type="text" name="name" value="{{product.name}}" required>
    </div>

    <div class="form-group">
      <label>Product Name (AR)</label>
      <input type="text" name="name_ar" value="{{product.name_ar}}">
    </div>

    <div class="form-group">
      <label>Description (EN)</label>
      <textarea name="description">{{product.description}}</textarea>
    </div>

    <div class="form-group">
      <label>Description (AR)</label>
      <textarea name="description_ar">{{product.description_ar}}</textarea>
    </div>

    <div class="form-group">
      <label>Price</label>
      <input type="number" step="0.01" name="price" value="{{product.price}}" required>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" name="hasOffer" {{#if product.hasOffer}}checked{{/if}}>
        Has Offer
      </label>
    </div>

    <div class="form-group">
      <label>Offer Price</label>
      <input type="number" step="0.01" name="offerPrice" value="{{product.offerPrice}}">
    </div>

    <div class="form-group">
      <label>Store</label>
      <select name="storeId" required>
        {{#each stores}}
          <option value="{{this._id}}" {{#ifEquals this._id ../product.storeId}}selected{{/ifEquals}}>
            {{this.name}}
          </option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label>Category</label>
      <select name="category" required>
        {{#each categories}}
          <option value="{{this.key}}" {{#ifEquals this.key ../product.category}}selected{{/ifEquals}}>
            {{this.name}}
          </option>
        {{/each}}
      </select>
    </div>

    <div class="form-group">
      <label>
        <input type="checkbox" name="inStock" {{#if product.inStock}}checked{{/if}}>
        In Stock
      </label>
    </div>

    <div class="form-group">
      <label>Current Image</label><br>
      {{#if product.image}}
        <img src="{{product.image}}" alt="{{product.name}}" width="120" style="border:1px solid #ddd; border-radius:8px;">
        <div style="margin-top:6px; color:#666; font-size:12px;">{{product.image}}</div>
      {{else}}
        <div style="color:#999;">No image saved</div>
      {{/if}}
    </div>

    <div class="form-group">
      <label>Replace Image (Upload)</label>
      <input type="file" name="image" accept="image/*">
    </div>

    <div class="form-group">
      <label>Or Choose Seed Image</label>
      <select name="seedImage">
        <option value="">-- Keep current / Select seed image --</option>
        <option value="flower-1.png">flower-1.png</option>
        <option value="flower-8.png">flower-8.png</option>
        <option value="child-care-1.png">child-care-1.png</option>
      </select>
    </div>

    <button type="submit" class="btn btn-success">Update Product</button>
    <a href="/backend/products/store/{{product.storeId}}" class="btn btn-secondary">Cancel</a>
  </form>
</div>