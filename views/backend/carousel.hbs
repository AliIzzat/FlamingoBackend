<div class="admin-container">
  <div class="admin-header">
    <h1>🎞️ Carousel Manager</h1>
    <p>Manage homepage slides for image, video, text, and actions.</p>
  </div>

  <div class="admin-card">
    <h2>{{#if editSlide}}Edit Slide{{else}}Add New Slide{{/if}}</h2>

    {{!-- <form action="/admin/carousel/save" method="POST" class="admin-form"> --}}
    <form action="/admin/carousel/save" method="POST" enctype="multipart/form-data"></form>
      {{#if editSlide}}
        <input type="hidden" name="id" value="{{editSlide._id}}" />
      {{/if}}

      <div class="form-row">
        <label>Media Type</label>
        <select name="type" class="input">
          <option value="image" {{#if (eq editSlide.type "image")}}selected{{/if}}>Image</option>
          <option value="video" {{#if (eq editSlide.type "video")}}selected{{/if}}>Video</option>
        </select>
      </div>

      <div class="form-row">
        <label>Upload Media (Image / Video)</label>
        <input type="file" name="media" class="input" accept="image/*,video/*" />
      </div>

      <div class="form-row">
        <label>Or Media URL (optional)</label>
        <input
          type="text"
          name="mediaUrl"
          class="input"
          placeholder="https://..."
          value="{{editSlide.mediaUrl}}"
        />
      </div>

      {{!-- <div class="form-row">
        <label>Media URL</label>
        <input
          type="text"
          name="mediaUrl"
          class="input"
          placeholder="https://..."
          value="{{editSlide.mediaUrl}}"
          required
        />
      </div> --}}

      <div class="form-row two-cols">
        <div>
          <label>Title (English)</label>
          <input type="text" name="title" class="input" value="{{editSlide.title}}" />
        </div>

        <div>
          <label>Title (Arabic)</label>
          <input type="text" name="titleAr" class="input" value="{{editSlide.titleAr}}" />
        </div>
      </div>

      <div class="form-row">
        <label>Description</label>
        <textarea name="description" class="input textarea">{{editSlide.description}}</textarea>
      </div>

      <div class="form-row two-cols">
        <div>
          <label>Button Text</label>
          <input type="text" name="buttonText" class="input" value="{{editSlide.buttonText}}" />
        </div>

        <div>
          <label>Sort Order</label>
          <input type="number" name="sortOrder" class="input" value="{{editSlide.sortOrder}}" />
        </div>
      </div>

      <div class="form-row two-cols">
        <div>
          <label>Action Type</label>
          <select name="actionType" class="input">
            <option value="none" {{#if (eq editSlide.actionType "none")}}selected{{/if}}>None</option>
            <option value="link" {{#if (eq editSlide.actionType "link")}}selected{{/if}}>External Link</option>
            <option value="navigate" {{#if (eq editSlide.actionType "navigate")}}selected{{/if}}>Navigate</option>
          </select>
        </div>

        <div>
          <label>Action Value</label>
          <input type="text" name="actionValue" class="input" value="{{editSlide.actionValue}}" />
        </div>
      </div>

      <div class="form-row switch-row">
        <label>Active</label>
        <input
          type="checkbox"
          name="isActive"
          {{#if editSlide}}
            {{#if editSlide.isActive}}checked{{/if}}
          {{else}}
            checked
          {{/if}}
        />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">
          {{#if editSlide}}💾 Update Slide{{else}}➕ Save Slide{{/if}}
        </button>

        {{#if editSlide}}
          <a href="/admin/carousel" class="btn-secondary">Cancel Edit</a>
        {{/if}}
      </div>
    </form>
  </div>

  <div class="admin-card">
    <h2>Existing Slides</h2>

    {{#if slides.length}}
      <div class="carousel-grid">
        {{#each slides}}
          <div class="carousel-item">
            <div class="carousel-preview">
              {{#if (eq type "image")}}
                <img src="{{mediaUrl}}" alt="{{title}}" />
              {{else}}
                <div class="video-placeholder">🎬 VIDEO</div>
              {{/if}}
            </div>

            <div class="carousel-info">
              <h3>{{title}}</h3>
              <p>{{description}}</p>

              <div class="meta">
                <span>Type: {{type}}</span>
                <span>Order: {{sortOrder}}</span>
              </div>

              <div class="meta">
                <span>Action: {{actionType}}</span>
                <span>{{#if isActive}}Active{{else}}Inactive{{/if}}</span>
              </div>
            </div>

            <div class="carousel-actions">
              <a href="/admin/carousel/edit/{{_id}}" class="btn-edit">Edit</a>

              <form action="/admin/carousel/delete/{{_id}}" method="POST" onsubmit="return confirm('Delete this slide?');">
                <button type="submit" class="btn-delete">Delete</button>
              </form>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <p>No slides found.</p>
    {{/if}}
  </div>
</div>

<style>
.admin-container {
  padding: 20px;
}

.admin-header h1 {
  margin-bottom: 6px;
  color: #6a0dad;
}

.admin-header p {
  color: #666;
}

.admin-card {
  background: #fff;
  border-radius: 16px;
  padding: 20px;
  margin-top: 20px;
  border: 1px solid #e5dbff;
}

.admin-form .form-row {
  margin-bottom: 14px;
  display: flex;
  flex-direction: column;
}

.two-cols {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}

.input {
  border: 1px solid #d8cfff;
  border-radius: 10px;
  padding: 10px;
}

.textarea {
  min-height: 90px;
}

.switch-row {
  flex-direction: row !important;
  justify-content: space-between;
  align-items: center;
}

.form-actions {
  margin-top: 16px;
  display: flex;
  gap: 10px;
  align-items: center;
}

.btn-primary {
  background: #6a0dad;
  color: #fff;
  padding: 10px 18px;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  text-decoration: none;
}

.btn-secondary {
  background: #f3efff;
  color: #6a0dad;
  padding: 10px 18px;
  border-radius: 10px;
  text-decoration: none;
  border: 1px solid #d8cfff;
}

.carousel-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 16px;
}

.carousel-item {
  border: 1px solid #eee;
  border-radius: 14px;
  overflow: hidden;
  background: #faf7ff;
  display: flex;
  flex-direction: column;
}

.carousel-preview img {
  width: 100%;
  height: 160px;
  object-fit: cover;
}

.video-placeholder {
  height: 160px;
  display: flex;
  justify-content: center;
  align-items: center;
  background: #eee;
  font-weight: bold;
  color: #666;
}

.carousel-info {
  padding: 12px;
}

.carousel-info h3 {
  margin: 0 0 8px 0;
  font-size: 16px;
}

.carousel-info p {
  margin: 0 0 10px 0;
  color: #666;
  min-height: 36px;
}

.meta {
  font-size: 12px;
  color: #777;
  display: flex;
  justify-content: space-between;
  margin-top: 4px;
}

.carousel-actions {
  display: flex;
  gap: 8px;
  padding: 12px;
  padding-top: 0;
}

.carousel-actions form {
  flex: 1;
  margin: 0;
}

.btn-edit,
.btn-delete {
  flex: 1;
  display: inline-block;
  text-align: center;
  padding: 10px;
  border-radius: 10px;
  text-decoration: none;
  border: none;
  cursor: pointer;
}

.btn-edit {
  background: #8c00ff;
  color: #fff;
}

.btn-delete {
  width: 100%;
  background: #f31ae8;
  color: #fff;
}
</style>